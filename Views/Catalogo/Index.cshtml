@{
    ViewData["Title"] = "Catálogo de Produtos";

    List<string> produtos = (List<string>)ViewBag.Produtos;
    List<decimal> precos = (List<decimal>)ViewBag.Precos;
}

<h2>Catálogo de Produtos</h2>

<table border="1">
    <thead>
        <tr>
            <th>#</th>
            <th>Nome</th>
            <th>Preço</th>
        </tr>
    </thead>

    <tbody>
        @for (int i = 0; i < produtos.Count; i++)
        {
            <tr>
                <td>@(i + 1)</td>
                <td>@produtos[i]</td>

                <td>
                    @if (precos[i] < 100)
                    {
                        <span style="color:green">
                            R$ @precos[i]
                        </span>
                    }
                    else
                    {
                        <span>
                            R$ @precos[i]
                        </span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<p>
    <strong>Total: @produtos.Count produtos</strong>
</p>